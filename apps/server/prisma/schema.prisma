generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  SUPPORT
  ACCOUNTS
  ADMIN
  SUPER_ADMIN
}

enum ContactMessageStatus {
  OPEN
  RESOLVED
  CANCELLED
}

enum OrderStatus {
  PENDING
  ACCEPTED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum DeploymentType {
  DOWNLOAD
  MANUAL
  AUTO_SSH
  AUTO_DOCKER
  AUTO_GIT
}

enum DeploymentStatus {
  PENDING
  PROCESSING
  SUCCESS
  FAILED
}

enum SubscriptionTier {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum ServerSubStatus {
  PENDING
  ACTIVE
  CANCELLED
  EXPIRED
  REJECTED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model User {
  id           String   @id @default(cuid())
  firstName    String   @db.VarChar(50)
  lastName     String   @db.VarChar(50)
  phone        String   @unique @db.VarChar(20)
  email        String   @unique @db.VarChar(255)
  passwordHash String   @db.Text
  avatarUrl    String?  @db.Text
  role         Role      @default(CLIENT)
  isActive     Boolean   @default(true)
  isVIP        Boolean   @default(false)
  bannedUntil  DateTime?
  deletedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  orders        Order[]
  sentMessages  Message[]    @relation("SentMessages")
  refreshTokens RefreshToken[]
  notifications Notification[]
  directConversations Conversation[] @relation("DirectConversations")
  servers       Server[]
  subscription Subscription?
  templateReviews TemplateReview[]
  customerProjects CustomerProject[]
  serverSubscriptions ServerSubscription[]

  @@index([email])
  @@index([phone])
  @@index([role])
  @@index([isActive])
  @@index([createdAt])
  @@index([role, isActive])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Template {
  id            String   @id @default(cuid())
  title         String   @db.VarChar(100)
  description   String   @db.Text
  category      String   @db.VarChar(50)
  price         Decimal  @db.Decimal(10, 2)
  previewUrl    String   @db.Text
  demoUrl       String?  @db.Text
  tags          String[]
  isPublished   Boolean  @default(false)
  defaultColors Json
  components    Json
  configSchema  Json?
  manifest      Json?
  gallery       String[]
  videoUrl      String?
  features      Json?
  templateType  String? @db.VarChar(30)
  framework     String? @db.VarChar(50)
  deploymentType String? @db.VarChar(20)
  deploymentScript String? @db.Text
  sourceUrl     String?  @db.Text
  sourceFile    String?  @db.Text
  sortOrder     Int      @default(0)
  deletedAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders  Order[]
  versions TemplateVersion[]
  fields  TemplateField[]
  assets  TemplateAsset[]
  reviews TemplateReview[]
  projects CustomerProject[]

  @@index([isPublished])
  @@index([category])
  @@index([sortOrder])
  @@index([category, isPublished])
  @@index([createdAt])
  @@map("templates")
}

model TemplateVersion {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version    String   @db.VarChar(20)
  changelog  String?  @db.Text
  fileUrl    String   @db.Text
  fileSize   Int      @default(0)
  isCurrent  Boolean  @default(false)
  channel    String   @default("stable") @db.VarChar(10)
  compatibleWith String? @db.VarChar(20)
  createdAt  DateTime @default(now())

  @@unique([templateId, version])
  @@index([templateId])
  @@map("template_versions")
}

model TemplateField {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  key        String   @db.VarChar(50)
  label      String   @db.VarChar(100)
  type       String   @db.VarChar(20)
  required   Boolean  @default(false)
  defaultValue String? @db.Text
  options    String[]
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([templateId, key])
  @@index([templateId])
  @@map("template_fields")
}

model TemplateAsset {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  type       String   @db.VarChar(20)
  url        String   @db.Text
  label      String?  @db.VarChar(200)
  fileSize   Int      @default(0)
  mimeType   String?  @db.VarChar(50)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@index([templateId])
  @@index([type])
  @@map("template_assets")
}

model TemplateReview {
  id         String   @id @default(cuid())
  templateId String
  template   Template @relation(fields: [templateId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  rating     Int
  comment    String?  @db.Text
  createdAt  DateTime @default(now())

  @@unique([templateId, userId])
  @@index([templateId])
  @@index([rating])
  @@map("template_reviews")
}

model CustomerProject {
  id         String   @id @default(cuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  templateId String
  template   Template @relation(fields: [templateId], references: [id])
  config     Json
  previewUrl String?  @db.Text
  publishedUrl String? @db.Text
  currentVersion String? @db.VarChar(20)
  availableVersion String? @db.VarChar(20)
  updateStatus String @default("up_to_date") @db.VarChar(15)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([templateId])
  @@map("customer_projects")
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  templateId    String
  template      Template    @relation(fields: [templateId], references: [id])
  status        OrderStatus @default(PENDING)
  customization Json
  totalAmount   Decimal     @db.Decimal(10, 2)
  notes         String?     @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  conversation Conversation?
  deployment   Deployment?
  customerProject CustomerProject?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([templateId])
  @@index([userId, status])
  @@index([status, createdAt])
  @@map("orders")
}

model Conversation {
  id        String   @id @default(cuid())
  orderId   String?  @unique
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  clientId  String?
  client    User?    @relation("DirectConversations", fields: [clientId], references: [id])
  type      String   @default("ORDER")
  title     String?  @db.VarChar(200)
  isOpen    Boolean  @default(true)
  deletedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@index([updatedAt])
  @@index([clientId])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  content        String       @db.Text
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())

  @@index([conversationId])
  @@index([createdAt])
  @@index([isRead])
  @@map("messages")
}

model LandingContent {
  id        String   @id @default(cuid())
  section   String   @unique @db.VarChar(50)
  content   Json
  updatedAt DateTime @updatedAt

  @@map("landing_content")
}

model ContactMessage {
  id        String               @id @default(cuid())
  name      String               @db.VarChar(100)
  email     String               @db.VarChar(255)
  phone     String?              @db.VarChar(20)
  subject   String               @db.VarChar(200)
  message   String               @db.Text
  isRead    Boolean              @default(false)
  status    ContactMessageStatus @default(OPEN)
  createdAt DateTime             @default(now())

  replies ContactReply[]

  @@index([createdAt])
  @@index([isRead])
  @@index([status])
  @@map("contact_messages")
}

model ContactReply {
  id        String         @id @default(cuid())
  messageId String
  message   ContactMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  content   String         @db.Text
  isAdmin   Boolean        @default(true)
  createdAt DateTime       @default(now())

  @@map("contact_replies")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String   @db.VarChar(200)
  body      String   @db.Text
  type      String   @db.VarChar(50)
  link      String?  @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

model Server {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label     String   @db.VarChar(100)
  host      String   @db.VarChar(255)
  port      Int      @default(22)
  username  String   @db.VarChar(100)
  authType  String   @default("PASSWORD") @db.VarChar(20)
  password  String?  @db.Text
  sshKey    String?  @db.Text
  domain    String?  @db.VarChar(255)
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deployments Deployment[]

  @@index([userId])
  @@map("servers")
}

model Deployment {
  id              String           @id @default(cuid())
  orderId         String           @unique
  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  serverId        String?
  server          Server?          @relation(fields: [serverId], references: [id])
  type            DeploymentType   @default(DOWNLOAD)
  status          DeploymentStatus @default(PENDING)
  domain          String?          @db.VarChar(255)
  sslEnabled      Boolean          @default(false)
  log             String?          @db.Text
  deployedVersion String?          @db.VarChar(20)
  completedAt     DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status])
  @@index([serverId])
  @@map("deployments")
}

model Subscription {
  id              String           @id @default(cuid())
  userId          String           @unique
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  tier            SubscriptionTier @default(FREE)
  maxTemplates    Int              @default(1)
  maxDeployments  Int              @default(0)
  maxServers      Int              @default(0)
  features        String[]
  price           Decimal          @db.Decimal(10, 2)
  startsAt        DateTime         @default(now())
  expiresAt       DateTime?
  autoRenew       Boolean          @default(false)
  stripeId        String?          @db.VarChar(100)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("subscriptions")
}

model ServerPlan {
  id            String               @id @default(cuid())
  name          String               @db.VarChar(100)
  description   String?              @db.Text
  features      String[]
  monthlyPrice  Decimal              @db.Decimal(10, 2)
  yearlyPrice   Decimal              @db.Decimal(10, 2)
  isActive      Boolean              @default(true)
  sortOrder     Int                  @default(0)
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  subscriptions ServerSubscription[]

  @@index([isActive])
  @@index([sortOrder])
  @@map("server_plans")
}

model ServerSubscription {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  planId        String
  plan          ServerPlan      @relation(fields: [planId], references: [id])
  status        ServerSubStatus @default(PENDING)
  billingCycle  BillingCycle    @default(MONTHLY)
  price         Decimal         @db.Decimal(10, 2)
  adminNotes    String?         @db.Text
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([userId])
  @@index([status])
  @@index([userId, status])
  @@map("server_subscriptions")
}

model Expense {
  id          String   @id @default(cuid())
  description String   @db.VarChar(300)
  amount      Decimal  @db.Decimal(10, 2)
  category    String   @db.VarChar(50)
  date        DateTime @default(now())
  notes       String?  @db.Text
  createdBy   String   @db.VarChar(100)
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
  @@index([category])
  @@map("expenses")
}
